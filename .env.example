# 복사해서 .env 로 저장하세요:  cp .env.example .env

# LLM 백엔드: mock | remote | local
#   mock   : 고정 메시지 응답 (비용 0, 기본)
#   remote : DeepSeek V4 API (아래 키 필요)
#   local  : 로컬 Ollama (gemma4:e4b 등, 비용 0)
LLM_BACKEND=mock

# remote (DeepSeek)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# local (Ollama):  ollama serve  /  ollama pull gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=gemma4:e4b

# 웹 검색 (Serper.dev = 구글). https://serper.dev 에서 무료 키 발급. 비우면 검색 비활성.
SERPER_API_KEY=

# Wake word ('Hey Jarvis')
WAKE_THRESHOLD=0.4      # 호출어 감지 임계값(0~1). 낮을수록 민감(잘 깨어남). 오발동 많으면 ↑, 잘 안되면 ↓(예: 0.3)
WAKE_COOLDOWN_S=2.0     # 연속 오발동 방지
LISTEN_TIMEOUT_S=8.0    # 호출 후 이 시간 무발화 시 대기 상태로 복귀

# 회의 자막 중계(meeting-web). 둘 다 비어있으면 비활성 — 콘솔만 출력.
# 로컬 dev: ws://localhost:8787,  배포: wss://meeting-web-jarvis.<acct>.workers.dev
RELAY_URL=
RELAY_TOKEN=

# 로컬 jarvis-web(wrangler dev) 연결용. ./run.sh --local 이 위 RELAY_URL/RELAY_TOKEN 을 이걸로 덮어씀.
# RELAY_TOKEN_LOCAL 은 jarvis-web/.dev.vars 의 RELAY_TOKEN 과 일치해야 함(기본 devtoken).
RELAY_URL_LOCAL=ws://localhost:8799
RELAY_TOKEN_LOCAL=devtoken

# /meet 진입 시 매번 묻지 않을 본인 이름. 회의 키 = {상대}_{USER_NAME}
USER_NAME=Concode

# IR 가전 제어 (eMotion Pro / MQTT). 브로커 IP/포트와 자격증명.
IOT_ENABLED=false
MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
