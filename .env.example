# 복사해서 .env 로 저장하세요:  cp .env.example .env

# LLM 백엔드: mock | remote | local
#   mock   : 고정 메시지 응답 (비용 0, 기본)
#   remote : DeepSeek V4 API (아래 키 필요)
#   local  : 로컬 Ollama (gemma4:e4b 등, 비용 0)
LLM_BACKEND=mock

# remote (DeepSeek)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# local (Ollama):  ollama serve  /  ollama pull gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=gemma4:e4b

# Wake word ('Hey Jarvis')
WAKE_THRESHOLD=0.5      # 호출어 감지 임계값(0~1). 오발동 많으면 ↑, 잘 안되면 ↓
WAKE_COOLDOWN_S=2.0     # 연속 오발동 방지
LISTEN_TIMEOUT_S=8.0    # 호출 후 이 시간 무발화 시 대기 상태로 복귀
